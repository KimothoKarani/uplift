# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://uplift:uplift@localhost:5432/uplift

# ── Encryption ────────────────────────────────────────────────────────────────
# 32-byte AES-256 key. Generate with:
#   openssl rand -base64 32
ENCRYPTION_KEY=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must match GOOGLE_REDIRECT_URI exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use test-mode keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
# Run: stripe listen --forward-to localhost:3000/stripe/webhook
# Paste the "whsec_..." secret it prints here.
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=uplift_api=debug,uplift_jobs=info,sqlx=warn

SQLX_OFFLINE=true

# ── SMTP (optional — skip to disable email) ───────────────────────────────────
#SMTP_HOST=smtp.postmarkapp.com
#SMTP_USERNAME=your-api-token
#SMTP_PASSWORD=your-api-token
#SMTP_FROM=hello@yourdomain.com